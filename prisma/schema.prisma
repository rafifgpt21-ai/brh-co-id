// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum AgendaCategory {
  TEACHING
  ENGAGEMENT
}

model User {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  username      String?         @unique
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role            @default(USER)
  phone         String?
  accounts      Account[]
  sessions      Session[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  titleEn   String?
  slug      String   @unique
  slugEn    String?  @unique
  category  String   // 'Buku', 'Jurnal', 'Artikel', 'Opini'
  status    String   @default("Draft") // 'Published' | 'Draft'
  thumbnail String?
  blocks    Block[]
  publishedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuickPost {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  type              String   // Legacy: 'NORMAL'; active: 'AGENDA' | 'QUOTE'
  agendaCategory    AgendaCategory?
  content           String
  imageUrl          String?
  sourcePostId      String?  @db.ObjectId
  sourceTitle       String?
  sourceSlug        String?
  agendaLink        String?
  startsAt          DateTime?
  endsAt            DateTime?
  locationLabel     String?
  locationLatitude  Float?
  locationLongitude Float?
  status            String   @default("Draft") // 'Published' | 'Draft'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model SiteSetting {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  key                 String   @unique
  homeFeaturedPostIds String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeChunk {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  sourceType String
  sourceId   String
  locale     String   @default("id")
  chunkIndex Int
  title      String
  url        String
  category   String?
  thumbnail  String?
  content    String
  embedding  Float[]
  indexedAt  DateTime @default(now())

  @@unique([sourceType, sourceId, locale, chunkIndex])
  @@index([sourceType, sourceId])
  @@index([locale])
}

type Block {
  id       String
  type     String // 'text', 'image', 'video', 'pdf', 'link'
  content  String
  contentEn String?
  url      String?
  title    String?
  titleEn  String?
  caption  String?
  captionEn String?
  isLocked Boolean? @default(false)
}

model RateLimit {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String   @unique // Bisa berupa IP Address, Email, atau kombinasi keduanya
  attempts   Int      @default(1)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([expiresAt]) // Indeks ini akan berguna untuk cleanup
}
